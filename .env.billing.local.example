# Copy to .env.billing.local (gitignored) — Stripe + Resend for API server deploy
# Run: npm run setup:stripe  then  npm run deploy:billing-env

# Stripe (required for setup:stripe)
STRIPE_SECRET_KEY=sk_test_...

# Filled automatically by npm run setup:stripe:
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_BUSINESS_YEARLY=price_...
# STRIPE_PRICE_LIFETIME=price_...

# Resend (add after creating key at resend.com)
RESEND_API_KEY=re_...
CONTACT_FROM_EMAIL=WhatsApp AI Desk <hello@wasup.app>
CONTACT_INBOX_EMAIL=support@wasup.app

# Webhook URL (reference — set automatically by setup:stripe)
# STRIPE_WEBHOOK_URL=https://api.wasup.app/api/stripe/webhook
