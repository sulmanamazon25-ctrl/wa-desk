# --- Admin gate (Electron) ---
# Unlock code before /dashboard loads (default 1997 if unset).
DESK_ADMIN_PIN=1997
# Set to 1 to skip the gate (automated tests / emergency local dev).
# DESK_GATE_DISABLED=1

# --- OpenRouter (recommended: unified chat + voice STT) ---
# Prefer saving in the app (Setup → API keys). Env fallback:
# OPENROUTER_API_KEY=
# OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
# OPENROUTER_STT_MODEL=openai/whisper-large-v3-turbo
# OPENROUTER_STT_MODEL_LIST=openai/whisper-large-v3-turbo,groq/whisper-large-v3-turbo

# --- Dev only: seed xAI key if disk has none (never commit real values) ---
# Copy to .env.local (gitignored). On startup the main process verifies and saves once.
# DEV_SEED_XAI_KEY=
# DEV_SEED_XAI_MODEL=grok-3

# --- xAI Grok (primary: chat + Grok STT) ---
# Optional env fallback; prefer saving keys in the app (API keys tab).
# XAI_API_KEY=
# XAI_CHAT_MODEL=grok-3
# Comma-separated xAI speech-to-text models (tried in order; default grok-stt).
# XAI_STT_MODEL_LIST=grok-stt
# Voice STT order: groq-first (default, Whisper) or xai-first (Grok STT).
# WWEBJS_VOICE_STT_ORDER=groq-first

# --- AI (optional Groq backup: chat + Whisper) ---
GROQ_API_KEY=

# Optional: comma-separated chat models (Groq tries in order after GROQ_MODEL)
# GROQ_MODEL_LIST=llama-3.3-70b-versatile,llama-3.1-8b-instant
# Groq Whisper for voice: whisper-large-v3-turbo,whisper-large-v3
# GROQ_WHISPER_MODEL_LIST=whisper-large-v3-turbo,whisper-large-v3

GROQ_MODEL=llama-3.3-70b-versatile

# WhatsApp: how many messages to load into AI context (10–200; default 80). Higher = more history, slower.
# WWEBJS_AI_FETCH_LIMIT=100
# Chromium for whatsapp-web.js (Puppeteer). Auto: Puppeteer Chrome → system Chrome → Edge (Win).
# WWEBJS_CHROME_EXECUTABLE=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# Or run once: npm run setup:chrome
# Max voice notes to transcribe (STT) when building AI thread per "Suggest" / auto-reply (0–20; default 8).
# WWEBJS_VOICE_TRANSCRIBE_FOR_AI_LIMIT=8
# Always transcribe the newest N inbound-only voice notes (1–25; default 12) so customer voice is not dropped when you sent many voice messages too.
# WWEBJS_VOICE_TRANSCRIBE_RECENT_CUSTOMER=12

# Draft queue: try to mirror AI text into WhatsApp Web's compose buffer (may sync draft to phone).
# WWEBJS_PHONE_DRAFT_SYNC=0   # set to 0 to disable
# WWEBJS_COMPOSE_DRAFT_OPEN_CHAT=1   # optional: focus that chat in the Web session first (more disruptive)

# Max milliseconds to wait after the last inbound message before building one draft (draft mode only; 1500–45000; default 6000).
# WWEBJS_DRAFT_DEBOUNCE_MS=6000

# Optional: inbound typing simulation overrides (electron main — see whatsapp-manager header).
# Paired MIN+MAX uniform delay (ms) before WhatsApp typing state; clamps 200–120000 each.
# WWEBJS_TYPING_DELAY_MIN_MS=800
# WWEBJS_TYPING_DELAY_MAX_MS=2200
# If min/max unset: scale default delay (0.25–4).
# WWEBJS_TYPING_DELAY_MULT=1
# Paired MIN+MAX after sendStateTyping before send (ms); else length-based delay + jitter 0..N (default jitter 400).
# WWEBJS_TYPING_POST_MIN_MS=
# WWEBJS_TYPING_POST_MAX_MS=
# WWEBJS_TYPING_POST_JITTER_MAX_MS=
# Voice STT: skip over cap — no transcript (bytes clamp 4096–52428800).
# WWEBJS_VOICE_STT_MAX_BYTES=
# Rough duration cap (estimated as bytes/2000 s, clamp env 1–900).
# WWEBJS_VOICE_STT_MAX_SECONDS=
# Optional: standalone voice-ai-assistant (Express) — same machine or LAN.
# When set, voice in Auto uses POST {URL}/upload-audio (STT+reply in one call); Draft debounce uses it for suggestions.
# Paused mode never calls this URL. Run the service from repo ../ViralEdgeMVP/voice-ai-assistant (npm start).
# WWEBJS_REMOTE_VOICE_AI_URL=http://127.0.0.1:8787
# WWEBJS_REMOTE_VOICE_AI_TIMEOUT_MS=180000


# Premium Grok image / sticker tools (in-app). Unlocked when: admin desk unlocked (PIN), DESK_GATE_DISABLED=1, or DESK_PREMIUM_MEDIA_UNLOCKED=1.
# DESK_PREMIUM_MEDIA_UNLOCKED=1
# DESK_PREMIUM_MEDIA_LOCKED=1   # force hide tools even in dev
# Primary image model (optional). If your team has no access, the app tries fallbacks from XAI_IMAGE_MODEL_LIST or a built-in list.
# XAI_IMAGE_MODEL=grok-imagine-image-quality
# Comma-separated fallbacks (optional).
# XAI_IMAGE_MODEL_LIST=grok-imagine-image-quality,grok-2-image,grok-imagine-image-pro

# --- Supabase (minimal: auth + optional cloud sync) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- License / SaaS (desktop → your VPS) ---
# Set when building the Windows installer or in packaged .env:
# DESK_LICENSE_SERVER_URL=https://yourdomain.com
# NEXT_PUBLIC_LICENSE_SERVER_URL=https://yourdomain.com
# NEXT_PUBLIC_SUPPORT_URL=https://yourdomain.com/support
# DESK_UPDATE_URL=https://yourdomain.com/release/

# --- VPS only (see .env.production.example + DEPLOY-VPS.md) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_BUSINESS_YEARLY=
# STRIPE_PRICE_LIFETIME=
# RESEND_API_KEY=
# LICENSE_SIGNING_SECRET=
# CONTACT_INBOX_EMAIL=
# CONTACT_FROM_EMAIL=
# DOWNLOAD_URL=
