# VPS / production — marketing site + Stripe + licenses
# Copy to .env.production on your server (never commit real secrets)

NEXT_PUBLIC_APP_URL=https://yourdomain.com
LICENSE_SIGNING_SECRET=change-me-to-a-long-random-string
LICENSE_DB_DIR=/var/lib/whatsapp-ai-desk

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_BUSINESS_YEARLY=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx

# Resend
RESEND_API_KEY=re_xxx
CONTACT_FROM_EMAIL=WhatsApp AI Desk <hello@yourdomain.com>
CONTACT_INBOX_EMAIL=support@yourdomain.com
SALES_EMAIL=sales@yourdomain.com

# Installer hosted on your server
DOWNLOAD_URL=https://yourdomain.com/release/WhatsApp-AI-Desk-Setup-latest.exe
NEXT_PUBLIC_DOWNLOAD_URL=https://yourdomain.com/release/WhatsApp-AI-Desk-Setup-latest.exe

# Optional live chat on marketing pages
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Desktop builds (set when running npm run dist:win)
DESK_LICENSE_SERVER_URL=http://194.9.62.143:3025
DESK_UPDATE_URL=http://194.9.62.143:3025/release/

# Postgres (wa-db on Coolify — internal hostname in production)
DATABASE_URL=postgresql://wa_desk:PASSWORD@wa-db:5432/wa_desk
ADMIN_API_KEY=change-me-admin-api-key
