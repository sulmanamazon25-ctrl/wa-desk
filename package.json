{
  "name": "whatsapp-ai-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Electron + Next.js desktop WhatsApp AI assistant",
  "main": "dist-electron/main.js",
  "author": "WhatsApp AI Desk",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "next dev -p 3000",
    "dev:electron": "npm run build:electron && wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run build:electron && next build",
    "dist:win": "node scripts/dist-win.mjs",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "smoke:marketing": "node scripts/smoke-marketing.mjs",
    "admin:license": "node scripts/create-admin-license.mjs",
    "gen:coolify-secrets": "node scripts/gen-coolify-secrets.mjs",
    "wait:deploy": "node scripts/wait-for-deploy.mjs",
    "publish:wa-desk-image": "node scripts/publish-wa-desk-image.mjs",
    "setup:chrome": "node scripts/install-puppeteer-chrome.mjs",
    "postinstall": "node scripts/install-puppeteer-chrome.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.3.9",
    "groq-sdk": "^0.15.0",
    "pg": "^8.13.1",
    "next": "^15.1.0",
    "qrcode": "^1.5.4",
    "openai": "^4.77.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.5.0",
    "whatsapp-web.js": "^1.26.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/qrcode": "^1.5.5",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
