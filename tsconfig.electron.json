{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "electron/**/*.d.ts", "shared/**/*.ts"]
}
